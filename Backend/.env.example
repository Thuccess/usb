# MongoDB Atlas (get connection string from Atlas → Connect → Drivers)
# Must use mongodb+srv:// protocol for DNS SRV records and automatic failover
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.6a12xxy.mongodb.net/moictusb?retryWrites=true&w=majority&appName=Cluster0

# JWT Secrets (generate strong random strings for production)
# Minimum 32 characters recommended
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=https://your-frontend.vercel.app,https://www.your-frontend.vercel.app

# Cloudinary (optional for dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (optional for dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Radio
DEFAULT_STREAM_URL=https://stream.example.com/bentiu990

# Admin seed
SEED_ADMIN_EMAIL=admin@unitystate.gov.ss
SEED_ADMIN_PASSWORD=ChangeMe123!
